---
import Layout from '../layouts/Layout.astro';
import { cliente } from '../data/cliente.js';

const c = cliente;
---

<Layout>

<!-- ═══════════════════════════════════════════════════════════════════
  1. HEADER / NAV
═══════════════════════════════════════════════════════════════════ -->
<header id="header">
  <div class="nav-inner">
    <a href="#inicio" class="logo" aria-label="Inicio Clínica Dental Lumia">
      <span class="logo-icon">
        <!-- Tooth SVG icon -->
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2C8.5 2 6 4.5 6 6.5c0 1.5.5 3 1 4.5C8 14 8 18 9 20s2 2 3 2 2-1 3-2 1-6 2-9c.5-1.5 1-3 1-4.5C18 4.5 15.5 2 12 2z"/>
        </svg>
      </span>
      <span class="logo-text">{c.nombreCorto}</span>
    </a>

    <nav class="nav-links" aria-label="Navegación principal">
      <a href="#especialidades">Servicios</a>
      <a href="#equipo">Equipo</a>
      <a href="#precios">Precios</a>
      <a href="#contacto">Contacto</a>
    </nav>

    <a href="#reserva" class="btn-cita btn-hover">Pedir cita gratis</a>

    <button class="nav-toggle" aria-label="Abrir menú" id="nav-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Menú móvil -->
  <nav class="nav-mobile" id="nav-mobile" aria-label="Menú móvil">
    <a href="#especialidades" class="nav-mobile-link">Servicios</a>
    <a href="#equipo"         class="nav-mobile-link">Equipo</a>
    <a href="#precios"        class="nav-mobile-link">Precios</a>
    <a href="#contacto"       class="nav-mobile-link">Contacto</a>
    <a href="#reserva"        class="nav-mobile-cta">Pedir cita gratis</a>
  </nav>
</header>


<!-- ═══════════════════════════════════════════════════════════════════
  2. HERO
═══════════════════════════════════════════════════════════════════ -->
<section id="inicio" class="hero">
  <div class="hero-bg" style={`background-image: url('/fotos/hero-clinica.jpg')`}></div>
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <p class="hero-eyebrow">Barrio de Salamanca, Madrid</p>
    <h1 class="hero-title">Tu mejor sonrisa<br/>empieza aquí</h1>
    <p class="hero-subtitle">Especialistas en implantología, ortodoncia y estética dental. Primera consulta gratuita y sin compromiso.</p>
    <div class="hero-actions">
      <a href="#reserva" class="btn-primary btn-hover">Pedir cita gratis</a>
      <a href="#especialidades" class="btn-secondary btn-hover">Ver servicios</a>
    </div>
  </div>

  <div class="hero-stats">
    <div class="hero-stat">
      <span class="hero-stat-num">4.9★</span>
      <span class="hero-stat-label">{c.valoraciones.totalResenas} reseñas</span>
    </div>
    <div class="hero-stat-divider"></div>
    <div class="hero-stat">
      <span class="hero-stat-num">+15</span>
      <span class="hero-stat-label">años de experiencia</span>
    </div>
    <div class="hero-stat-divider"></div>
    <div class="hero-stat">
      <span class="hero-stat-num">3.000+</span>
      <span class="hero-stat-label">pacientes satisfechos</span>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  3. PRESENTACIÓN
═══════════════════════════════════════════════════════════════════ -->
<section id="quienes-somos" class="section-presentacion">
  <div class="container">
    <div class="presentacion-grid">
      <div class="presentacion-text">
        <p class="eyebrow anim" style="--i:0">Quiénes somos</p>
        <h2 class="section-title anim" style="--i:1">{c.tagline}</h2>
        <p class="section-desc anim" style="--i:2">{c.descripcionLarga}</p>
        <a href="#reserva" class="btn-accent btn-hover anim" style="--i:3">Primera consulta sin coste →</a>
      </div>
      <div class="presentacion-cifras anim-children">
        <div class="cifra-card">
          <span class="cifra-num">15+</span>
          <span class="cifra-label">Años de experiencia</span>
        </div>
        <div class="cifra-card">
          <span class="cifra-num">3.000+</span>
          <span class="cifra-label">Pacientes atendidos</span>
        </div>
        <div class="cifra-card">
          <span class="cifra-num">4.9★</span>
          <span class="cifra-label">Valoración media</span>
        </div>
        <div class="cifra-card">
          <span class="cifra-num">3</span>
          <span class="cifra-label">Especialistas colegiados</span>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  4. ESPECIALIDADES
═══════════════════════════════════════════════════════════════════ -->
<section id="especialidades" class="section-alt">
  <div class="container">
    <p class="eyebrow text-center anim" style="--i:0">Nuestros servicios</p>
    <h2 class="section-title text-center anim" style="--i:1">Todo lo que tu sonrisa necesita</h2>
    <p class="section-desc text-center anim" style="--i:2">Un equipo especializado para cada tratamiento. Sin derivaciones innecesarias.</p>

    <div class="especialidades-grid anim-children">
      {c.especialidades.map((esp) => (
        <div class="esp-card card-hover">
          <div class="esp-icon">
            {esp.icono === 'tooth'   && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8.5 2 6 4.5 6 6.5c0 1.5.5 3 1 4.5C8 14 8 18 9 20s2 2 3 2 2-1 3-2 1-6 2-9c.5-1.5 1-3 1-4.5C18 4.5 15.5 2 12 2z"/></svg>}
            {esp.icono === 'braces'  && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="8" rx="2"/><line x1="8" y1="8" x2="8" y2="16"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="16" y1="8" x2="16" y2="16"/></svg>}
            {esp.icono === 'implant' && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22"/><path d="M7 6h10M8 10h8M9 14h6"/></svg>}
            {esp.icono === 'star'    && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>}
            {esp.icono === 'shield'  && <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
          </div>
          <h3 class="esp-title">{esp.nombre}</h3>
          <p class="esp-desc">{esp.descripcion}</p>
          <a href="#reserva" class="esp-link">Pedir cita →</a>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  5. EQUIPO
═══════════════════════════════════════════════════════════════════ -->
<section id="equipo" class="section">
  <div class="container">
    <p class="eyebrow text-center anim" style="--i:0">Nuestro equipo</p>
    <h2 class="section-title text-center anim" style="--i:1">Especialistas que puedes conocer antes de venir</h2>
    <p class="section-desc text-center anim" style="--i:2">Saber quién te va a tratar genera confianza. Por eso somos transparentes.</p>

    <div class="equipo-grid anim-children">
      {c.equipo.map((doc) => (
        <div class="doc-card card-hover">
          <div class="doc-img img-zoom">
            <img src={doc.foto} alt={doc.fotoAlt} width="400" height="320" loading="lazy" />
          </div>
          <div class="doc-body">
            <h3 class="doc-nombre">{doc.nombre}</h3>
            <p class="doc-cargo">{doc.cargo}</p>
            <p class="doc-colegiado">{doc.colegiado}</p>
            <p class="doc-bio">{doc.bio}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  6. ANTES / DESPUÉS
═══════════════════════════════════════════════════════════════════ -->
<section id="casos" class="section-alt">
  <div class="container">
    <p class="eyebrow text-center anim" style="--i:0">Resultados reales</p>
    <h2 class="section-title text-center anim" style="--i:1">Antes y después</h2>
    <p class="section-desc text-center anim" style="--i:2">Casos reales de pacientes de Clínica Dental Lumia. Resultados que hablan por sí solos.</p>

    <div class="casos-grid anim-children">
      {c.casosAntesDepues.map((caso) => (
        <div class="caso-card card-hover">
          <div class="caso-comparativa">
            <div class="caso-lado">
              <span class="caso-badge badge-antes">Antes</span>
              <div class="img-zoom caso-img">
                <img src={caso.fotoAntes} alt={caso.fotoAntesAlt} width="400" height="260" loading="lazy" />
              </div>
            </div>
            <div class="caso-lado">
              <span class="caso-badge badge-despues">Después</span>
              <div class="img-zoom caso-img">
                <img src={caso.fotoDespues} alt={caso.fotoDespuesAlt} width="400" height="260" loading="lazy" />
              </div>
            </div>
          </div>
          <div class="caso-info">
            <h3 class="caso-titulo">{caso.titulo}</h3>
            <p class="caso-desc">{caso.descripcion}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  7. TABLA DE PRECIOS
═══════════════════════════════════════════════════════════════════ -->
<section id="precios" class="section">
  <div class="container">
    <p class="eyebrow text-center anim" style="--i:0">Transparencia total</p>
    <h2 class="section-title text-center anim" style="--i:1">Precios claros, sin sorpresas</h2>
    <p class="section-desc text-center anim" style="--i:2">Primera visita gratuita. Financiación sin intereses hasta 12 meses.</p>

    <div class="precios-grid anim-children">
      {c.servicios.map((srv) => (
        <div class={`precio-card card-hover ${srv.destacado ? 'precio-destacado' : ''}`}>
          {srv.badge && <span class="precio-badge">{srv.badge}</span>}
          <h3 class="precio-nombre">{srv.nombre}</h3>
          {srv.nota && <p class="precio-nota">{srv.nota}</p>}
          <div class="precio-valor">
            {srv.precio === 0
              ? <span class="precio-gratis">Gratis</span>
              : srv.precioDesde
                ? <span><em>desde</em> {srv.precioDesde}€</span>
                : <span>{srv.precio}€</span>
            }
          </div>
          {srv.duracionMin && <p class="precio-duracion">{srv.duracionMin} min aprox.</p>}
          <a href="#reserva" class="precio-cta btn-hover">Pedir cita →</a>
        </div>
      ))}
    </div>
    <p class="precios-aviso anim">* Precios orientativos. El presupuesto definitivo se facilita tras la exploración inicial.</p>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  8. RESERVA TU CITA (CALENDLY)
═══════════════════════════════════════════════════════════════════ -->
<section id="reserva" class="section-reserva">
  <div class="container">
    <div class="reserva-header">
      <p class="eyebrow eyebrow-light anim" style="--i:0">Sin esperas</p>
      <h2 class="section-title text-inverse anim" style="--i:1">Reserva tu cita en 2 minutos</h2>
      <p class="section-desc text-inverse anim" style="--i:2">Elige el día y la hora que mejor te venga. Confirmación instantánea por email.</p>
    </div>

    <div class="calendly-wrapper anim" style="--i:3">
      <div
        class="calendly-inline-widget"
        data-url={c.calendlyUrl}
        style="min-width:320px;height:700px;"
      ></div>
      <script async src="https://assets.calendly.com/assets/external/widget.js"></script>
    </div>

    <p class="reserva-tel anim" style="--i:4">
      ¿Prefieres llamar? <a href={`tel:${c.contacto.telefono.replace(/\s/g, '')}`}>{c.contacto.telefono}</a>
    </p>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  9. SEGUROS ACEPTADOS
═══════════════════════════════════════════════════════════════════ -->
<section id="seguros" class="section-alt">
  <div class="container">
    <p class="eyebrow text-center anim" style="--i:0">Convenios</p>
    <h2 class="section-title text-center anim" style="--i:1">Trabajamos con tu seguro</h2>
    <p class="section-desc text-center anim" style="--i:2">Consultamos la cobertura de tu póliza antes de comenzar cualquier tratamiento.</p>

    <div class="seguros-grid anim-children">
      {c.seguros.map((seguro) => (
        <div class="seguro-badge">
          <span>{seguro.nombre}</span>
        </div>
      ))}
    </div>

    <p class="seguros-aviso anim">¿No ves tu seguro? Consúltanos — trabajamos con más de 15 compañías.</p>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  10. TESTIMONIOS
═══════════════════════════════════════════════════════════════════ -->
<section id="testimonios" class="section">
  <div class="container">
    <p class="eyebrow text-center anim" style="--i:0">Lo que dicen nuestros pacientes</p>
    <h2 class="section-title text-center anim" style="--i:1">{c.valoraciones.rating}★ en Google — {c.valoraciones.totalResenas} reseñas</h2>

    <div class="testimonios-grid anim-children">
      {c.testimonios.map((t) => (
        <div class="testimonio-card card-hover">
          <div class="testimonio-stars">{'★'.repeat(t.rating)}</div>
          <p class="testimonio-texto">"{t.texto}"</p>
          <div class="testimonio-footer">
            <span class="testimonio-nombre">{t.nombre}</span>
            <span class="testimonio-servicio">{t.servicio}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  11. DIFERENCIALES
═══════════════════════════════════════════════════════════════════ -->
<section id="diferenciales" class="section-alt">
  <div class="container">
    <p class="eyebrow text-center anim" style="--i:0">Por qué elegirnos</p>
    <h2 class="section-title text-center anim" style="--i:1">Más que una clínica dental</h2>

    <div class="diferenciales-grid anim-children">
      {c.diferenciales.map((d) => (
        <div class="diferencial-item">
          <div class="diferencial-icon">
            {d.icono === 'monitor'      && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>}
            {d.icono === 'clock'        && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>}
            {d.icono === 'accessibility'&& <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="4" r="2"/><path d="M7 9h10l-1 6H8L7 9z"/><path d="M9 15l-1 6M15 15l1 6"/></svg>}
            {d.icono === 'credit-card'  && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>}
          </div>
          <h3 class="diferencial-titulo">{d.titulo}</h3>
          <p class="diferencial-desc">{d.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  12. CONTACTO + MAPA
═══════════════════════════════════════════════════════════════════ -->
<section id="contacto" class="section">
  <div class="container">
    <p class="eyebrow text-center anim" style="--i:0">Dónde estamos</p>
    <h2 class="section-title text-center anim" style="--i:1">Visítanos en Madrid</h2>

    <div class="contacto-grid">
      <div class="contacto-info anim-left">
        <div class="contacto-dato">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <div>
            <strong>Dirección</strong>
            <p>{c.contacto.direccion}<br/>{c.contacto.codigoPostal} {c.contacto.ciudad}</p>
          </div>
        </div>

        <div class="contacto-dato">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <div>
            <strong>Teléfono</strong>
            <p><a href={`tel:${c.contacto.telefono.replace(/\s/g, '')}`}>{c.contacto.telefono}</a></p>
          </div>
        </div>

        <div class="contacto-dato">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <div>
            <strong>Email</strong>
            <p><a href={`mailto:${c.contacto.email}`}>{c.contacto.email}</a></p>
          </div>
        </div>

        <div class="horario-tabla">
          <strong>Horario</strong>
          <table>
            {c.horario.map((h) => (
              <tr class={h.cerrado ? 'horario-cerrado' : ''}>
                <td>{h.dia}</td>
                <td>{h.horas}</td>
              </tr>
            ))}
          </table>
        </div>
      </div>

      <div class="mapa-wrapper anim-right">
        <iframe
          src={c.mapa.embedUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Mapa de ${c.nombre}`}
        ></iframe>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════════
  13. FOOTER
═══════════════════════════════════════════════════════════════════ -->
<footer id="footer">
  <div class="footer-cta">
    <div class="container">
      <h2 class="footer-cta-title anim">¿Listo para tener la sonrisa que siempre has querido?</h2>
      <p class="footer-cta-desc anim" style="--i:1">Primera consulta gratuita. Sin compromiso. Sin letra pequeña.</p>
      <a href="#reserva" class="btn-primary btn-lg btn-hover anim" style="--i:2">Pedir cita gratis</a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <div class="footer-brand">
        <span class="logo-text">{c.nombreCorto}</span>
        <p>{c.contacto.direccion} · {c.contacto.ciudad}</p>
        <p><a href={`tel:${c.contacto.telefono.replace(/\s/g, '')}`}>{c.contacto.telefono}</a></p>
      </div>
      <div class="footer-links">
        <a href="#">Política de privacidad</a>
        <a href="#">Aviso legal</a>
        <a href="#">Política de cookies</a>
      </div>
      <div class="footer-social">
        {c.social.instagram && <a href={c.social.instagram} aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>}
        {c.social.facebook && <a href={c.social.facebook} aria-label="Facebook" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>}
      </div>
    </div>
    <p class="footer-copy">© {new Date().getFullYear()} {c.nombre} · Demo generada por <a href="https://intellipyme.es">Intellipyme</a></p>
  </div>
</footer>


<!-- ═══════════════════════════════════════════════════════════════════
  NAV MOBILE SCRIPT
═══════════════════════════════════════════════════════════════════ -->
<script>
  const toggle = document.getElementById('nav-toggle');
  const mobile = document.getElementById('nav-mobile');
  toggle?.addEventListener('click', () => {
    mobile?.classList.toggle('open');
    toggle.classList.toggle('open');
  });
  mobile?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobile.classList.remove('open');
      toggle?.classList.remove('open');
    });
  });
</script>


